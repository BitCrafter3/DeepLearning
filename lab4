import numpy as np
import time
import matplotlib.pyplot as plt
from tensorflow.keras.models import Sequential
from tensorflow.keras.layers import SimpleRNN, LSTM, GRU, Dense

# 🔹 Generate Dummy Time-Series Data
def generate_data(samples=1000, timesteps=10):
    X = np.random.rand(samples, timesteps, 1)
    y = np.sum(X, axis=1)  # simple pattern
    return X, y

X, y = generate_data()

# Split data
split = int(0.8 * len(X))
X_train, X_test = X[:split], X[split:]
y_train, y_test = y[:split], y[split:]

# 🔹 Model Builder
def build_model(model_type):
    model = Sequential()

    if model_type == "RNN":
        model.add(SimpleRNN(32, input_shape=(10, 1)))
    elif model_type == "LSTM":
        model.add(LSTM(32, input_shape=(10, 1)))
    elif model_type == "GRU":
        model.add(GRU(32, input_shape=(10, 1)))

    model.add(Dense(1))
    model.compile(optimizer='adam', loss='mse')
    return model

# 🔹 Train and Evaluate Models
models = ["RNN", "LSTM", "GRU"]
results = {}

for m in models:
    print(f"\nTraining {m}...")
    model = build_model(m)

    start = time.time()
    history = model.fit(X_train, y_train, epochs=5, batch_size=32, verbose=0)
    training_time = time.time() - start

    loss = model.evaluate(X_test, y_test, verbose=0)

    results[m] = (loss, training_time)

# 🔹 Print Results
print("\n📊 Results Comparison:")
for m in results:
    print(f"{m} -> Loss: {results[m][0]:.4f}, Time: {results[m][1]:.2f}s")
